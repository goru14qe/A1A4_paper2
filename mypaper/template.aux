\@writefile{lof}{\contentsline {figure}{\numberline {10}{\ignorespaces Flow-locking visual for the $30^\circ $ packing at Pos\,3: time-mean velocity-magnitude fields with in-plane streamlines for all fifteen layers L03-L17, each de-rotated by $-n\theta $ into the common reference frame, at (a)\nobreakspace  {}$Re_P = 100$ and (b)\nobreakspace  {}$Re_P = 300$. After de-rotation the layers collapse onto a single repeating pore-scale pattern-the central jet, flanking slit jets and recirculation pockets recur in every layer-demonstrating that the mean flow follows the geometric twist-and-repeat rule at both Reynolds numbers.\relax }}{23}{figure.caption.13}\protected@file@percent }
\newlabel{fig:lockvis}{{10}{23}{Flow-locking visual for the $30^\circ $ packing at Pos\,3: time-mean velocity-magnitude fields with in-plane streamlines for all fifteen layers L03-L17, each de-rotated by $-n\theta $ into the common reference frame, at (a)~$Re_P = 100$ and (b)~$Re_P = 300$. After de-rotation the layers collapse onto a single repeating pore-scale pattern-the central jet, flanking slit jets and recirculation pockets recur in every layer-demonstrating that the mean flow follows the geometric twist-and-repeat rule at both Reynolds numbers.\relax }{figure.caption.13}{}}
\@writefile{lof}{\contentsline {subfigure}{\numberline{(a)}{\ignorespaces {$Re_P = 100$}}}{23}{subfigure.10.1}\protected@file@percent }
\@writefile{lof}{\contentsline {subfigure}{\numberline{(b)}{\ignorespaces {$Re_P = 300$}}}{23}{subfigure.10.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {11}{\ignorespaces Locking order parameter for the three topologies at $Re_P = 100$ (Pos\,3). Left: the layer-to-layer matrix $L$ (Eq.\nobreakspace  {}\ref  {eq:Ln}) evaluated on the pairwise fluid mask; right: per-layer locking $L(n)$ against the across-layer mean field. The (a)\nobreakspace  {}$30^\circ $ and (b)\nobreakspace  {}$40^\circ $ packings lock at $L \approx 1.00$ and $0.99$ respectively, whereas (c)\nobreakspace  {}the irregular packing scatters between $L = 0.10$ and $0.68$ with no systematic repeat, confirming that the geometric period is required for locking.\relax }}{24}{figure.caption.14}\protected@file@percent }
\newlabel{fig:Ln}{{11}{24}{Locking order parameter for the three topologies at $Re_P = 100$ (Pos\,3). Left: the layer-to-layer matrix $L$ (Eq.~\ref {eq:Ln}) evaluated on the pairwise fluid mask; right: per-layer locking $L(n)$ against the across-layer mean field. The (a)~$30^\circ $ and (b)~$40^\circ $ packings lock at $L \approx 1.00$ and $0.99$ respectively, whereas (c)~the irregular packing scatters between $L = 0.10$ and $0.68$ with no systematic repeat, confirming that the geometric period is required for locking.\relax }{figure.caption.14}{}}
\@writefile{lof}{\contentsline {subfigure}{\numberline{(a)}{\ignorespaces {$30^\circ $, $Re_P=100$}}}{24}{subfigure.11.1}\protected@file@percent }
\@writefile{lof}{\contentsline {subfigure}{\numberline{(b)}{\ignorespaces {$40^\circ $, $Re_P=100$}}}{24}{subfigure.11.2}\protected@file@percent }
