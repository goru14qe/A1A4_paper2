\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces Layer-resolved validation for the regular $30^\circ $ packing at $Re_P = 100$, Pos\,3 (layers L13-L17). (a)\nobreakspace  {}Time-mean velocity-magnitude contours with in-plane streamlines, experiment (left) versus simulation (right); (b)\nobreakspace  {}velocity-magnitude profiles at $2\,\mathrm  {mm}$ above the lower layer face, simulation (red, dashed) versus PIV (blue) for each layer. The layers carry essentially the same profile (flow locking) and the simulation reproduces it in every layer; the simulated jet maxima sit a few percent below the measured values, consistent with mild numerical diffusion of the under-resolved jet cores.\relax }}{19}{figure.caption.11}\protected@file@percent }
\newlabel{fig:validation_layers}{{8}{19}{Layer-resolved validation for the regular $30^\circ $ packing at $Re_P = 100$, Pos\,3 (layers L13-L17). (a)~Time-mean velocity-magnitude contours with in-plane streamlines, experiment (left) versus simulation (right); (b)~velocity-magnitude profiles at $2\,\mathrm {mm}$ above the lower layer face, simulation (red, dashed) versus PIV (blue) for each layer. The layers carry essentially the same profile (flow locking) and the simulation reproduces it in every layer; the simulated jet maxima sit a few percent below the measured values, consistent with mild numerical diffusion of the under-resolved jet cores.\relax }{figure.caption.11}{}}
\@writefile{lof}{\contentsline {subfigure}{\numberline{(a)}{\ignorespaces {exp.\ (left) vs.\ sim.\ (right) velocity-magnitude contours and streamlines}}}{19}{subfigure.8.1}\protected@file@percent }
\@writefile{lof}{\contentsline {subfigure}{\numberline{(b)}{\ignorespaces {per-layer profiles at $2\,\mathrm {mm}$ from the lower face, sim.\ (red) vs.\ PIV (blue)}}}{19}{subfigure.8.2}\protected@file@percent }
\citation{velten2026}
\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces Layer-resolved validation for the irregular packing at $Re_P = 100$, Pos\,3. (a)\nobreakspace  {}Time-mean velocity-magnitude contours with in-plane streamlines, experiment (left) versus simulation (right); (b)\nobreakspace  {}per-layer velocity-magnitude profiles at $2\,\mathrm  {mm}$ above the lower face, simulation (red, dashed) versus PIV (blue). Each layer is reproduced individually, but the profiles differ strongly from layer to layer with no common shape: unlike the regular packing, the irregular layers carry no coherent profile to collapse, so they are shown only in the per-layer format.\relax }}{20}{figure.caption.12}\protected@file@percent }
\newlabel{fig:validation_layers_irreg}{{9}{20}{Layer-resolved validation for the irregular packing at $Re_P = 100$, Pos\,3. (a)~Time-mean velocity-magnitude contours with in-plane streamlines, experiment (left) versus simulation (right); (b)~per-layer velocity-magnitude profiles at $2\,\mathrm {mm}$ above the lower face, simulation (red, dashed) versus PIV (blue). Each layer is reproduced individually, but the profiles differ strongly from layer to layer with no common shape: unlike the regular packing, the irregular layers carry no coherent profile to collapse, so they are shown only in the per-layer format.\relax }{figure.caption.12}{}}
