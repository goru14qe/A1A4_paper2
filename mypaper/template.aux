\@writefile{lof}{\contentsline {figure}{\numberline {12}{\ignorespaces Reynolds-number weakening of flow locking for the $30^\circ $ packing (Pos\,3). (a)\nobreakspace  {}Ratio of turbulent kinetic energy to mean-flow kinetic energy, $k/k_{\rm  mean}$, per layer: at $Re_P = 100$ the curve is flat (coefficient of variation $2.2\%$, fluctuations locked layer to layer), whereas at $Re_P = 300$ the level doubles and the scatter grows five-fold (CoV $11.9\%$). (b)\nobreakspace  {}Per-layer mean speed at $Re_P = 300$, whose milder scatter (CoV $4.9\%$ vs $1.4\%$ at $Re_P = 100$) shows the same trend in the mean field. The fluctuation field is the more sensitive indicator of locking breakdown.\relax }}{26}{figure.caption.16}\protected@file@percent }
\newlabel{fig:tke}{{12}{26}{Reynolds-number weakening of flow locking for the $30^\circ $ packing (Pos\,3). (a)~Ratio of turbulent kinetic energy to mean-flow kinetic energy, $k/k_{\rm mean}$, per layer: at $Re_P = 100$ the curve is flat (coefficient of variation $2.2\%$, fluctuations locked layer to layer), whereas at $Re_P = 300$ the level doubles and the scatter grows five-fold (CoV $11.9\%$). (b)~Per-layer mean speed at $Re_P = 300$, whose milder scatter (CoV $4.9\%$ vs $1.4\%$ at $Re_P = 100$) shows the same trend in the mean field. The fluctuation field is the more sensitive indicator of locking breakdown.\relax }{figure.caption.16}{}}
\@writefile{lof}{\contentsline {subfigure}{\numberline{(a)}{\ignorespaces {per-layer fluctuation energy}}}{26}{subfigure.12.1}\protected@file@percent }
\@writefile{lof}{\contentsline {subfigure}{\numberline{(b)}{\ignorespaces {mean speed per layer, $Re_P=300$}}}{26}{subfigure.12.2}\protected@file@percent }
