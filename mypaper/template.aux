\@writefile{lof}{\contentsline {figure}{\numberline {13}{\ignorespaces Resolved turbulent kinetic energy field $k$ in a representative layer (L10) of the $30^\circ $ packing at Pos\,3, for $Re_P = 100$ (left) and $Re_P = 300$ (right); note the ten-fold change in colour scale. The fluctuations concentrate in the central-jet shear layer and the bar wakes-the layer-to-layer hand-off interfaces-and intensify and spread as the Reynolds number rises, identifying where the locked state first breaks down.\relax }}{27}{figure.caption.17}\protected@file@percent }
\newlabel{fig:tkefield}{{13}{27}{Resolved turbulent kinetic energy field $k$ in a representative layer (L10) of the $30^\circ $ packing at Pos\,3, for $Re_P = 100$ (left) and $Re_P = 300$ (right); note the ten-fold change in colour scale. The fluctuations concentrate in the central-jet shear layer and the bar wakes-the layer-to-layer hand-off interfaces-and intensify and spread as the Reynolds number rises, identifying where the locked state first breaks down.\relax }{figure.caption.17}{}}
